# Copy to .env and fill in values before running docker compose up.
# All variables have sensible defaults for local Docker Compose usage.

# ── MLflow ────────────────────────────────────────────────────────────────────
# Tracking server URL.  In Docker Compose this is http://mlflow:5000.
# For local dev without Docker: http://localhost:5001
MLFLOW_TRACKING_URI=http://mlflow:5000

# Registered model name in the MLflow model registry.
MLFLOW_MODEL_NAME=FailureClassifier

# Minimum macro-F1 required to promote a new model version to @champion.
# 0.70 is calibrated to the AI4I 2020 3-feature XGBoost (~0.737 macro-F1 achieved).
# Macro-F1 is penalised by the ~4% minority class; 0.85 would never be met.
F1_THRESHOLD=0.70

# ── Data paths ────────────────────────────────────────────────────────────────
# Shared CSV files — must be consistent across twin-sim, pipeline-api, and Dagster.
# In Docker Compose both services mount ./data → /app/shared, so use that path.
TELEMETRY_PATH=data/telemetry_stream.csv
PREDICTIONS_PATH=data/predictions.csv

# ── Pipeline API ──────────────────────────────────────────────────────────────
# Internal URL used by Dagster's write_predictions asset.
PIPELINE_API_URL=http://pipeline-api:8000

# ── Twin ──────────────────────────────────────────────────────────────────────
# Machine identifier written into every telemetry row.
MACHINE_ID=M-001

# ── dbt ───────────────────────────────────────────────────────────────────────
# Path to the DuckDB database file (relative to repo root).
DUCKDB_PATH=data/warehouse.duckdb
DBT_PROJECT_DIR=dbt
DBT_PROFILES_DIR=dbt
# BigQuery target (run with `--target bigquery`). Set GCP_PROJECT (+ optional
# BQ_DATASET/BQ_LOCATION), authenticate with `gcloud auth application-default
# login`, and load the raw table first via scripts/bq_load_telemetry.sh.
# See CLAUDE.md → Layer 3.
# GCP_PROJECT=
# BQ_DATASET=industrial_intelligence
# BQ_LOCATION=US

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password. Change this before exposing Grafana to a network.
GRAFANA_ADMIN_PASSWORD=admin
